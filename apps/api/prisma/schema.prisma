// OUSSOURI AI — 全量数据库 Schema（Step 4 设计的展开实现）
// 约定：
// - 跨限界上下文引用一律为无约束 UUID 列（模块解耦，不建 FK）；同聚合内使用 @relation。
// - 加密列 xxxEnc(Bytes) + 盲索引 xxxBidx；所有唯一索引在 migration 中改为部分索引 WHERE deleted_at IS NULL。
// - pgvector 列与 HNSW/GIN/分区/CHECK 约束在 migration 手写 SQL 中补充。

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  schemas    = ["core", "audit", "analytics"]
  extensions = [vector, pgcrypto]
}

// ============================================================
// Kernel（平台内核）
// ============================================================

model CodeRule {
  id         String    @id @default(uuid()) @db.Uuid
  entityType String    @unique
  prefix     String
  pattern    String
  seqLength  Int       @default(6)
  jumpMax    Int       @default(7)
  currentSeq BigInt    @default(0)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?   @db.Uuid
  updatedBy  String?   @db.Uuid
  deletedAt  DateTime?
  version    Int       @default(0)

  @@map("code_rules")
  @@schema("core")
}

enum VisibilityEffect {
  ALLOW
  MASK
  DENY

  @@schema("core")
}

model VisibilityPolicy {
  id          String           @id @default(uuid()) @db.Uuid
  resource    String
  field       String
  role        String
  contextRule Json?
  effect      VisibilityEffect
  maskPattern String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String?          @db.Uuid
  updatedBy   String?          @db.Uuid
  deletedAt   DateTime?
  version     Int              @default(0)

  @@unique([resource, field, role])
  @@map("visibility_policies")
  @@schema("core")
}

model StateMachine {
  id          String            @id @default(uuid()) @db.Uuid
  code        String            @unique
  states      Json
  transitions StateTransition[]
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   String?           @db.Uuid
  updatedBy   String?           @db.Uuid
  deletedAt   DateTime?
  version     Int               @default(0)

  @@map("state_machines")
  @@schema("core")
}

model StateTransition {
  id           String       @id @default(uuid()) @db.Uuid
  machineCode  String
  machine      StateMachine @relation(fields: [machineCode], references: [code])
  fromState    String
  toState      String
  allowedRoles String[]
  guard        Json?
  emitsEvent   String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  createdBy    String?      @db.Uuid
  updatedBy    String?      @db.Uuid
  deletedAt    DateTime?
  version      Int          @default(0)

  @@unique([machineCode, fromState, toState])
  @@map("state_transitions")
  @@schema("core")
}

enum TranslationStatus {
  MACHINE_DRAFT
  REVIEWED

  @@schema("core")
}

model EntityTranslation {
  id         String            @id @default(uuid()) @db.Uuid
  entityType String
  entityId   String            @db.Uuid
  field      String
  locale     String
  value      String
  status     TranslationStatus @default(MACHINE_DRAFT)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  createdBy  String?           @db.Uuid
  updatedBy  String?           @db.Uuid
  deletedAt  DateTime?
  version    Int               @default(0)

  @@unique([entityType, entityId, field, locale])
  @@index([entityType, entityId])
  @@index([status])
  @@map("entity_translations")
  @@schema("core")
}

model ExchangeRate {
  id        String   @id @default(uuid()) @db.Uuid
  base      String
  quote     String
  rate      Decimal  @db.Decimal(12, 6)
  source    String
  asOf      DateTime
  createdAt DateTime @default(now())

  @@unique([base, quote, asOf])
  @@map("exchange_rates")
  @@schema("core")
}

model Country {
  id           String    @id @default(uuid()) @db.Uuid
  iso2         String    @unique
  currencyCode String
  vatRate      Decimal?  @db.Decimal(5, 2)
  euMember     Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  version      Int       @default(0)

  @@map("countries")
  @@schema("core")
}

model ConfigEntry {
  id        String    @id @default(uuid()) @db.Uuid
  namespace String
  key       String
  value     Json
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?
  version   Int       @default(0)

  @@unique([namespace, key])
  @@map("config_entries")
  @@schema("core")
}

model OutboxEvent {
  id          String    @id @default(uuid()) @db.Uuid
  aggregate   String
  eventType   String
  payload     Json
  createdAt   DateTime  @default(now())
  publishedAt DateTime?

  @@index([publishedAt, createdAt])
  @@map("outbox_events")
  @@schema("core")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  actorId    String?  @db.Uuid
  actorRole  String?
  action     String
  targetType String?
  targetId   String?  @db.Uuid
  diff       Json?
  reason     String?
  ip         String?
  userAgent  String?
  occurredAt DateTime @default(now())

  @@index([actorId, occurredAt])
  @@index([targetType, targetId, occurredAt])
  @@map("audit_logs")
  @@schema("audit")
}

enum Sensitivity {
  LOW
  HIGH

  @@schema("core")
}

enum EscalationStatus {
  PENDING
  APPROVED
  DENIED
  EXPIRED

  @@schema("core")
}

model AccessEscalation {
  id          String           @id @default(uuid()) @db.Uuid
  requesterId String           @db.Uuid
  targetType  String
  targetId    String           @db.Uuid
  fields      String[]
  reason      String
  sensitivity Sensitivity
  status      EscalationStatus @default(PENDING)
  approvedBy  String?          @db.Uuid
  windowUntil DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  createdBy   String?          @db.Uuid
  updatedBy   String?          @db.Uuid
  deletedAt   DateTime?
  version     Int              @default(0)

  @@index([status, createdAt])
  @@index([requesterId, createdAt])
  @@map("access_escalations")
  @@schema("core")
}

// ============================================================
// IAM（身份与访问）
// ============================================================

enum UserStatus {
  ACTIVE
  LOCKED
  DISABLED

  @@schema("core")
}

model User {
  id            String     @id @default(uuid()) @db.Uuid
  emailEnc      Bytes
  emailBidx     String     @unique
  phoneEnc      Bytes?
  phoneBidx     String?
  passwordHash  String?
  displayName   String
  locale        String     @default("en")
  totpSecretEnc Bytes?
  status        UserStatus @default(ACTIVE)
  lastLoginAt   DateTime?
  roles         UserRole[]
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     String?    @db.Uuid
  updatedBy     String?    @db.Uuid
  deletedAt     DateTime?
  version       Int        @default(0)

  @@index([phoneBidx])
  @@map("users")
  @@schema("core")
}

model OAuthAccount {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  provider    String
  providerUid String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?
  version     Int       @default(0)

  @@unique([provider, providerUid])
  @@index([userId])
  @@map("oauth_accounts")
  @@schema("core")
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  code        String           @unique
  isInternal  Boolean          @default(false)
  permissions RolePermission[]
  users       UserRole[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
  version     Int              @default(0)

  @@map("roles")
  @@schema("core")
}

model Permission {
  id        String           @id @default(uuid()) @db.Uuid
  code      String           @unique
  roles     RolePermission[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  deletedAt DateTime?
  version   Int              @default(0)

  @@map("permissions")
  @@schema("core")
}

enum DataScope {
  OWN
  PARTY
  ALL

  @@schema("core")
}

model RolePermission {
  id           String     @id @default(uuid()) @db.Uuid
  roleId       String     @db.Uuid
  role         Role       @relation(fields: [roleId], references: [id])
  permissionId String     @db.Uuid
  permission   Permission @relation(fields: [permissionId], references: [id])
  dataScope    DataScope  @default(OWN)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  deletedAt    DateTime?
  version      Int        @default(0)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
  @@schema("core")
}

model UserRole {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  user      User      @relation(fields: [userId], references: [id])
  roleId    String    @db.Uuid
  role      Role      @relation(fields: [roleId], references: [id])
  createdAt DateTime  @default(now())
  createdBy String?   @db.Uuid
  deletedAt DateTime?
  version   Int       @default(0)

  @@unique([userId, roleId])
  @@map("user_roles")
  @@schema("core")
}

model Session {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  refreshHash String    @unique
  ip          String?
  expiresAt   DateTime
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId, expiresAt])
  @@map("sessions")
  @@schema("core")
}

// ============================================================
// Party（交易主体）— 真实身份唯一存放地
// ============================================================

enum PartyType {
  SUPPLIER
  BUYER
  BOTH

  @@schema("core")
}

enum PartyStatus {
  PENDING
  ACTIVE
  SUSPENDED
  INACTIVE

  @@schema("core")
}

model Organization {
  id                String           @id @default(uuid()) @db.Uuid
  publicCode        String           @unique
  partyType         PartyType
  legalNameEnc      Bytes
  legalNameBidx     String
  registrationNoEnc Bytes?
  taxIdEnc          Bytes?
  legalRepEnc       Bytes?
  addressEnc        Bytes?
  countryIso2       String
  status            PartyStatus      @default(PENDING)
  approvedBy        String?          @db.Uuid
  approvedAt        DateTime?
  riskNotes         String?
  contacts          Contact[]
  certificates      PartyCertificate[]
  addresses         Address[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String?          @db.Uuid
  updatedBy         String?          @db.Uuid
  deletedAt         DateTime?
  version           Int              @default(0)

  @@index([legalNameBidx])
  @@index([partyType, status])
  @@map("organizations")
  @@schema("core")
}

model Membership {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  orgId     String    @db.Uuid
  orgRole   String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  @@unique([userId, orgId])
  @@index([orgId])
  @@map("memberships")
  @@schema("core")
}

model Contact {
  id          String       @id @default(uuid()) @db.Uuid
  orgId       String       @db.Uuid
  org         Organization @relation(fields: [orgId], references: [id])
  nameEnc     Bytes
  positionEnc Bytes?
  phoneEnc    Bytes?
  emailEnc    Bytes?
  imEnc       Bytes?
  isPrimary   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  createdBy   String?      @db.Uuid
  updatedBy   String?      @db.Uuid
  deletedAt   DateTime?
  version     Int          @default(0)

  @@index([orgId])
  @@map("contacts")
  @@schema("core")
}

model SupplierProfile {
  id                String    @id @default(uuid()) @db.Uuid
  orgId             String    @unique @db.Uuid
  establishedAt     DateTime?
  registeredCapital Decimal?  @db.Decimal(14, 2)
  businessScope     String?
  tier              String?
  exportReady       Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?
  version           Int       @default(0)

  @@map("supplier_profiles")
  @@schema("core")
}

enum BuyerType {
  WHOLESALER
  RETAILER
  RESTAURANT
  IMPORTER
  DISTRIBUTOR

  @@schema("core")
}

model BuyerProfile {
  id             String    @id @default(uuid()) @db.Uuid
  orgId          String    @unique @db.Uuid
  buyerType      BuyerType
  city           String?
  creditScore    Decimal   @default(60) @db.Decimal(5, 1)
  totalPurchases Decimal   @default(0) @db.Decimal(14, 2)
  churnRiskAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?
  version        Int       @default(0)

  @@map("buyer_profiles")
  @@schema("core")
}

model Address {
  id           String       @id @default(uuid()) @db.Uuid
  orgId        String       @db.Uuid
  org          Organization @relation(fields: [orgId], references: [id])
  label        String
  recipientEnc Bytes
  phoneEnc     Bytes
  line1Enc     Bytes
  cityEnc      Bytes
  postcode     String?
  countryIso2  String
  isDefault    Boolean      @default(false)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  createdBy    String?      @db.Uuid
  updatedBy    String?      @db.Uuid
  deletedAt    DateTime?
  version      Int          @default(0)

  @@index([orgId])
  @@map("addresses")
  @@schema("core")
}

enum CertStatus {
  PENDING
  VALID
  EXPIRED
  REJECTED

  @@schema("core")
}

model PartyCertificate {
  id         String       @id @default(uuid()) @db.Uuid
  orgId      String       @db.Uuid
  org        Organization @relation(fields: [orgId], references: [id])
  certType   String
  certNo     String
  issuer     String?
  issueDate  DateTime?
  expiryDate DateTime?
  fileKey    String?
  status     CertStatus   @default(PENDING)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  createdBy  String?      @db.Uuid
  updatedBy  String?      @db.Uuid
  deletedAt  DateTime?
  version    Int          @default(0)

  @@index([orgId, certType])
  @@index([expiryDate])
  @@map("party_certificates")
  @@schema("core")
}

// ============================================================
// Catalog（商品目录）
// ============================================================

model Category {
  id               String    @id @default(uuid()) @db.Uuid
  code             String    @unique
  parentId         String?   @db.Uuid
  industryTemplate String?
  sortOrder        Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?   @db.Uuid
  updatedBy        String?   @db.Uuid
  deletedAt        DateTime?
  version          Int       @default(0)

  @@map("categories")
  @@schema("core")
}

model Species {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique
  latinName     String
  citesAppendix String?
  fatherCode    String?
  motherCode    String?
  maturityYears String?
  avgEggSizeMm  Decimal?  @db.Decimal(4, 2)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?
  version       Int       @default(0)

  @@map("species")
  @@schema("core")
}

model Grade {
  id           String    @id @default(uuid()) @db.Uuid
  code         String    @unique
  categoryCode String
  criteria     Json?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?   @db.Uuid
  updatedBy    String?   @db.Uuid
  deletedAt    DateTime?
  version      Int       @default(0)

  @@map("grades")
  @@schema("core")
}

enum ProductStatus {
  DRAFT
  PENDING_REVIEW
  ACTIVE
  INACTIVE
  DISCONTINUED

  @@schema("core")
}

model Product {
  id              String        @id @default(uuid()) @db.Uuid
  publicCode      String        @unique
  supplierOrgId   String        @db.Uuid
  categoryCode    String
  speciesCode     String?
  gradeCode       String?
  hsCode          String
  originCountry   String
  originDetailEnc Bytes?
  sourceLocale    String        @default("zh-CN")
  name            String
  description     String?
  status          ProductStatus @default(DRAFT)
  publishedAt     DateTime?
  skus            ProductSku[]
  media           ProductMedia[]
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  createdBy       String?       @db.Uuid
  updatedBy       String?       @db.Uuid
  deletedAt       DateTime?
  version         Int           @default(0)

  @@index([categoryCode, speciesCode, gradeCode, status])
  @@index([supplierOrgId, status])
  @@map("products")
  @@schema("core")
}

enum SkuStatus {
  ACTIVE
  INACTIVE

  @@schema("core")
}

model ProductSku {
  id             String      @id @default(uuid()) @db.Uuid
  productId      String      @db.Uuid
  product        Product     @relation(fields: [productId], references: [id])
  skuCode        String      @unique
  packSpec       String
  netWeightKg    Decimal     @db.Decimal(12, 3)
  unit           String
  moq            Decimal     @default(1) @db.Decimal(10, 2)
  shelfLifeDays  Int?
  storageTempMin Decimal?    @db.Decimal(4, 1)
  storageTempMax Decimal?    @db.Decimal(4, 1)
  status         SkuStatus   @default(ACTIVE)
  priceTiers     PriceTier[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      String?     @db.Uuid
  updatedBy      String?     @db.Uuid
  deletedAt      DateTime?
  version        Int         @default(0)

  @@index([productId])
  @@map("product_skus")
  @@schema("core")
}

model PriceTier {
  id            String     @id @default(uuid()) @db.Uuid
  skuId         String     @db.Uuid
  sku           ProductSku @relation(fields: [skuId], references: [id])
  currency      String
  qtyMin        Decimal    @db.Decimal(10, 2)
  qtyMax        Decimal?   @db.Decimal(10, 2)
  unitPrice     Decimal    @db.Decimal(14, 2)
  effectiveFrom DateTime
  effectiveTo   DateTime?
  isActive      Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  createdBy     String?    @db.Uuid
  updatedBy     String?    @db.Uuid
  deletedAt     DateTime?
  version       Int        @default(0)

  @@index([skuId, currency, isActive])
  @@map("price_tiers")
  @@schema("core")
}

enum MediaKind {
  IMAGE
  VIDEO
  DOC

  @@schema("core")
}

model ProductMedia {
  id        String    @id @default(uuid()) @db.Uuid
  productId String    @db.Uuid
  product   Product   @relation(fields: [productId], references: [id])
  kind      MediaKind
  fileKey   String
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
  version   Int       @default(0)

  @@index([productId])
  @@map("product_media")
  @@schema("core")
}

// ============================================================
// Traceability（溯源，行业无关）
// ============================================================

enum ActiveStatus {
  ACTIVE
  INACTIVE

  @@schema("core")
}

model ProductionUnit {
  id            String       @id @default(uuid()) @db.Uuid
  supplierOrgId String       @db.Uuid
  unitType      String
  nameEnc       Bytes
  locationEnc   Bytes
  countryIso2   String
  attributes    Json
  status        ActiveStatus @default(ACTIVE)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  createdBy     String?      @db.Uuid
  updatedBy     String?      @db.Uuid
  deletedAt     DateTime?
  version       Int          @default(0)

  @@index([supplierOrgId])
  @@map("production_units")
  @@schema("core")
}

model ProductionSubunit {
  id         String    @id @default(uuid()) @db.Uuid
  unitId     String    @db.Uuid
  name       String
  attributes Json
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  createdBy  String?   @db.Uuid
  updatedBy  String?   @db.Uuid
  deletedAt  DateTime?
  version    Int       @default(0)

  @@index([unitId])
  @@map("production_subunits")
  @@schema("core")
}

enum SourceBatchStatus {
  GROWING
  HARVESTED
  SOLD
  CLOSED

  @@schema("core")
}

model SourceBatch {
  id          String            @id @default(uuid()) @db.Uuid
  subunitId   String            @db.Uuid
  batchNo     String
  speciesCode String?
  quantity    Int?
  avgWeightKg Decimal?          @db.Decimal(8, 2)
  ageMonths   Int?
  originType  String?
  rfidStart   String?
  rfidEnd     String?
  status      SourceBatchStatus @default(GROWING)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  createdBy   String?           @db.Uuid
  updatedBy   String?           @db.Uuid
  deletedAt   DateTime?
  version     Int               @default(0)

  @@unique([subunitId, batchNo])
  @@map("source_batches")
  @@schema("core")
}

model IndividualAsset {
  id            String    @id @default(uuid()) @db.Uuid
  sourceBatchId String    @db.Uuid
  rfid          String    @unique
  gender        String?
  birthDate     DateTime?
  weightKg      Decimal?  @db.Decimal(8, 2)
  lengthCm      Decimal?  @db.Decimal(6, 2)
  healthStatus  String    @default("HEALTHY")
  status        String    @default("ALIVE")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdBy     String?   @db.Uuid
  updatedBy     String?   @db.Uuid
  deletedAt     DateTime?
  version       Int       @default(0)

  @@index([sourceBatchId])
  @@map("individual_assets")
  @@schema("core")
}

enum CareType {
  FEEDING
  HEALTH
  MEDICATION
  MORTALITY

  @@schema("core")
}

model CareRecord {
  id              String    @id @default(uuid()) @db.Uuid
  sourceBatchId   String    @db.Uuid
  recordType      CareType
  recordDate      DateTime
  payload         Json
  withdrawalUntil DateTime?
  operator        String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?   @db.Uuid
  updatedBy       String?   @db.Uuid
  deletedAt       DateTime?
  version         Int       @default(0)

  @@index([sourceBatchId, recordType, recordDate])
  @@map("care_records")
  @@schema("core")
}

enum QcStatus {
  IN_PROGRESS
  COMPLETED
  QC_PASS
  QC_FAIL

  @@schema("core")
}

model ProcessingBatch {
  id             String           @id @default(uuid()) @db.Uuid
  supplierOrgId  String           @db.Uuid
  sourceBatchId  String?          @db.Uuid
  batchNo        String
  categoryCode   String
  speciesCode    String?
  rawWeightKg    Decimal          @db.Decimal(12, 3)
  outputWeightKg Decimal          @db.Decimal(12, 3)
  processedAt    DateTime
  attributes     Json
  qcStatus       QcStatus         @default(IN_PROGRESS)
  steps          ProcessingStep[]
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  createdBy      String?          @db.Uuid
  updatedBy      String?          @db.Uuid
  deletedAt      DateTime?
  version        Int              @default(0)

  @@unique([supplierOrgId, batchNo])
  @@map("processing_batches")
  @@schema("core")
}

model ProcessingStep {
  id                String          @id @default(uuid()) @db.Uuid
  processingBatchId String          @db.Uuid
  processingBatch   ProcessingBatch @relation(fields: [processingBatchId], references: [id])
  stepCode          String
  startAt           DateTime?
  endAt             DateTime?

  id             String    @id @default(uuid()) @db.Uuid
  brokerUserId   String    @db.Uuid
  targetOrgId    String    @db.Uuid
  opportunityId  String?   @db.Uuid
  providerCallId String?
  startedAt      DateTime?
  durationSec    Int?
  outcome        String?
  recordingKey   String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  version        Int       @default(0)

  @@index([brokerUserId, createdAt])
  @@map("call_logs")
  @@schema("core")
}

// ============================================================
// Communication（IM 与通知）
// ============================================================

model Conversation {
  id           String                    @id @default(uuid()) @db.Uuid
  topicType    String
  topicId      String?                   @db.Uuid
  status       String                    @default("ACTIVE")
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  createdBy    String?                   @db.Uuid
  updatedBy    String?                   @db.Uuid
  deletedAt    DateTime?
  version      Int                       @default(0)

  @@index([topicType, topicId])
  @@map("conversations")
  @@schema("core")
}

model ConversationParticipant {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  orgId          String?      @db.Uuid
  userId         String       @db.Uuid
  partRole       String
  createdAt      DateTime     @default(now())
  deletedAt      DateTime?
  version        Int          @default(0)

  @@unique([conversationId, userId])
  @@map("conversation_participants")
  @@schema("core")
}

model Message {
  id             String       @id @default(uuid()) @db.Uuid
  conversationId String       @db.Uuid
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  senderUserId   String       @db.Uuid
  body           String
  attachments    Json?
  translatedBody Json?
  readBy         Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?
  version        Int          @default(0)

  @@index([conversationId, createdAt])
  @@map("messages")
  @@schema("core")
}

model MessageBlockEvent {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  conversationId String?  @db.Uuid
  matchedRule    String
  rawExcerpt     String
  occurredAt     DateTime @default(now())

  @@index([userId, occurredAt])
  @@map("message_block_events")
  @@schema("audit")
}

model NotificationTemplate {
  id        String    @id @default(uuid()) @db.Uuid
  code      String    @unique
  channels  String[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?
  version   Int       @default(0)

  @@map("notification_templates")
  @@schema("core")
}

model Notification {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  templateCode String
  channel      String
  payload      Json
  status       String    @default("PENDING")
  sentAt       DateTime?
  readAt       DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  version      Int       @default(0)

  @@index([userId, status])
  @@map("notifications")
  @@schema("core")
}

model NotificationPreference {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @db.Uuid
  templateCode String
  channel      String
  enabled      Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  version      Int       @default(0)

  @@unique([userId, templateCode, channel])
  @@map("notification_preferences")
  @@schema("core")
}

// ============================================================
// AI Platform（vector 列在 migration 中以 ALTER TABLE 添加 vector(1536) + HNSW）
// ============================================================

model ProductEmbedding {
  skuId       String   @id @db.Uuid
  contentHash String
  updatedAt   DateTime @updatedAt

  @@map("product_embeddings")
  @@schema("core")
}

model DemandEmbedding {
  buyerOrgId String   @id @db.Uuid
  updatedAt  DateTime @updatedAt

  @@map("demand_embeddings")
  @@schema("core")
}

model KnowledgeDocument {
  id        String    @id @default(uuid()) @db.Uuid
  title     String
  docKind   String
  locale    String
  fileKey   String?
  status    String    @default("ACTIVE")
  chunks    KnowledgeChunk[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  createdBy String?   @db.Uuid
  updatedBy String?   @db.Uuid
  deletedAt DateTime?
  version   Int       @default(0)

  @@map("knowledge_documents")
  @@schema("core")
}

model KnowledgeChunk {
  id         String            @id @default(uuid()) @db.Uuid
  documentId String            @db.Uuid
  document   KnowledgeDocument @relation(fields: [documentId], references: [id])
  seq        Int
  content    String

  @@unique([documentId, seq])
  @@map("knowledge_chunks")
  @@schema("core")
}

model LlmCallLog {
  id          String   @id @default(uuid()) @db.Uuid
  task        String
  provider    String
  model       String
  tokensIn    Int
  tokensOut   Int
  costEur     Decimal? @db.Decimal(10, 6)
  latencyMs   Int
  actorUserId String?  @db.Uuid
  createdAt   DateTime @default(now())

  @@index([task, createdAt])
  @@map("llm_call_logs")
  @@schema("analytics")
}

# ===== 生产环境模板：复制为 .env.production，放在仓库根（已被 gitignore）=====
NODE_ENV=production
API_PORT=3001
WEB_URL=https://oussouri.fr

# --- Database（compose 内网主机名 postgres）---
POSTGRES_USER=oussouri
POSTGRES_PASSWORD=CHANGE-ME-STRONG
POSTGRES_DB=oussouri
DATABASE_URL="postgresql://oussouri:CHANGE-ME-STRONG@postgres:5432/oussouri?schema=core"
REDIS_URL="redis://redis:6379"

# --- 安全密钥（openssl rand -hex 32 各生成一个，泄露即全量轮换）---
JWT_SECRET=CHANGE-ME-64-hex
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_TTL_DAYS=30
PII_ENCRYPTION_KEY=CHANGE-ME-64-hex
PII_BLIND_INDEX_KEY=CHANGE-ME-64-hex

# --- Ports/Adapters（生产必须为真实密钥；占位值会导致 API 拒绝启动）---
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=sk-xxx
EMBEDDING_PROVIDER=openai
OPENAI_API_KEY=sk-xxx
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=xxx
S3_ENDPOINT=https://s3.gra.io.cloud.ovh.net
S3_REGION=gra
S3_ACCESS_KEY=xxx
S3_SECRET_KEY=xxx
S3_BUCKET_PRIVATE=oussouri-private
S3_BUCKET_PUBLIC=oussouri-public
S3_BUCKET_BACKUP=oussouri-backup
SMTP_URL=smtp://user:pass@smtp.example.com:587
MAIL_FROM="Oussouri Caviar HUB <no-reply@oussouri.fr>"
